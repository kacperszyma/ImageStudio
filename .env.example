# Database
DATABASE_CONNECTION_STRING=
# Inference provider (start with one)
FAL_API_KEY=
# Cloud Storage (generated images)
GCS_BUCKET_NAME=
# Local dev only — points the GCS client at the fake-gcs-server container
# (docker-compose) instead of real GCS. Leave unset in prod.
STORAGE_EMULATOR_HOST=
# Stripe (test mode)
STRIPE_SECRET_KEY=
# Identity (Entra External ID)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Auth0 JWT audience — optional, defaults to https://imagestudio-api
AUTH_AUDIENCE=
