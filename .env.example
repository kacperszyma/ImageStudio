# Database
DATABASE_CONNECTION_STRING=
# Inference provider (start with one)
FAL_API_KEY=
# Cloud Storage (generated images)
GCS_BUCKET_NAME=
# Local dev only — points the GCS client at the fake-gcs-server container
# (docker-compose) instead of real GCS. Leave unset in prod.
STORAGE_EMULATOR_HOST=
# Stripe (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public URL Stripe posts events to — must match the endpoint you create in
# the Stripe dashboard/CLI, e.g. https://your-domain/stripe/webhook
STRIPE_WEBHOOK_URL=
STRIPE_RETURN_URL=
# Identity (Entra External ID)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Auth0 JWT audience — optional, defaults to https://imagestudio-api
AUTH_AUDIENCE=
# Frontend: base URL of the backend API. Leave unset for local dev
# (defaults to http://localhost:5253). Must be set at build time in prod.
VITE_API_URL=
